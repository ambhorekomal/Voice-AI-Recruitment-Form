# Google Gemini (conversation + form extraction)
GEMINI_API_KEY=

# Cartesia Sonic TTS — get API key at https://cartesia.ai (Dashboard → API keys)
# Voice ID: open https://play.cartesia.ai , pick a voice, copy its ID (UUID)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Optional Cartesia overrides (defaults work for most projects)
# CARTESIA_MODEL_ID=sonic-3
# CARTESIA_VERSION=2025-04-16

# Server (Render sets PORT automatically)
# PORT=3000
